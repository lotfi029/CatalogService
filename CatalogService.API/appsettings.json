{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Key": "",
    "Issure": "UserService",
    "Audiance": "Ecommerce Users",
    "ExpiryMinutes": 30
  },
  "AllowedHosts": "*",
  "ElasticSettings": {
    "Uri": "http://localhost:9200",
    "Username": "",
    "Password": "",
    "DefaultIndex": "catalog",
    "NumberOfShards": 3,
    "NumberOfReplicas": 2,
    "EnableDebugMode": false,
    "RequestTimeout": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "host=localhost;port=5432;database=catalogservice_v01;username=postgres;password=String"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  }
}
